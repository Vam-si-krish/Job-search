# =============================================================
#  Job Application Assistant — Configuration
#  Copy this file to ".env" and fill in your values.
#  (Never commit your real .env — it holds secret keys.)
# =============================================================

# ---- 1. Pick which AI provider to use -----------------------
#  Options: anthropic | openai | google | groq | openrouter | deepseek
AI_PROVIDER=anthropic

# ---- 2. Paste your API key(s) -------------------------------
#  You only need the key for the provider you chose above.
#  Leave the others blank.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=

# ---- 3. Pick the model --------------------------------------
#  anthropic : claude-sonnet-4-6   (recommended) | claude-opus-4-8
#  openai    : gpt-4o | gpt-4o-mini
#  google    : gemini-2.0-flash
#  groq      : llama-3.3-70b-versatile
#  deepseek  : deepseek-chat | deepseek-reasoner
AI_MODEL=claude-sonnet-4-6

# ---- 4. Default output mode ---------------------------------
#  auto  = detect question vs email automatically  (recommended)
#  form  = always answer as a short form field
#  email = always write a full email reply
OUTPUT_MODE=auto

# ---- 5. File locations (usually leave as-is) ----------------
PROFILE_PATH=./profile.json
SYSTEM_PROMPT_PATH=./system-prompt.md
